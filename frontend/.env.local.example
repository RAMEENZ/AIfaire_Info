NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Affiche le bouton « Ingérer » (déclenchement manuel de l'ingestion) dans la
# barre de statut. À réserver au dev/local : en production, l'endpoint est
# protégé par INGEST_API_KEY (que le front public ne peut pas transmettre).
NEXT_PUBLIC_ENABLE_INGEST_BUTTON=true
