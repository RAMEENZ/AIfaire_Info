DATABASE_URL=postgresql+asyncpg://faire_info:password@localhost:5432/faire_info

# Mistral AI (prioritaire sur Ollama quand la clé est renseignée)
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
METEO_FRANCE_API_KEY=
APP_ENV=development
LOG_LEVEL=INFO

# Documentation interactive (Swagger /docs, ReDoc /redoc, /openapi.json).
# Désactivée par défaut pour ne pas exposer la surface API. true en local.
ENABLE_DOCS=false

# Clé protégeant POST /api/ingest/run. Vide = pas d'auth (dev). En prod,
# générer une valeur forte : openssl rand -hex 24
INGEST_API_KEY=

# Scheduler
SCHEDULER_TIMEZONE=Europe/Paris
SCHEDULER_HOUR_MORNING=9
SCHEDULER_HOUR_MIDDAY=13
SCHEDULER_HOUR_EVENING=19
SCHEDULER_HOUR_NIGHT=23

# API defaults
DEFAULT_SINCE_HOURS=48
DEFAULT_EVENTS_LIMIT=500
MAX_EVENTS_LIMIT=1000

# Plafond de flux SSE /events/stream simultanés (au-delà : 503, repli polling).
MAX_SSE_CONNECTIONS=100

# CORS : origines autorisées, séparées par des virgules.
# "*" = toutes (API publique en lecture seule). En production, restreindre :
# CORS_ORIGINS=https://faire.info,https://www.faire.info
CORS_ORIGINS=*

# Cloudflare Tunnel (accès distant) — token du tunnel créé dans
# Zero Trust → Networks → Tunnels. cloudflared joint nginx:80 en interne.
# CLOUDFLARE_TUNNEL_TOKEN=
